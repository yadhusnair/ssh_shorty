#!/bin/bash
# s-admin-watch — background daemon: polls SYNC_HOST for access requests,
# sends a desktop pop-up only when NEW requests arrive.

CONFIG_DIR="$HOME/.config/ssh_shorty"
SEEN_CACHE="$CONFIG_DIR/.watch_seen_reqs"

SYNC_HOST=""
SYNC_REMOTE_PATH="validation/machines.txt"
SHORTY_WATCH_INTERVAL=60   # seconds between checks; override in config
[[ -f "$CONFIG_DIR/config" ]] && source "$CONFIG_DIR/config"

RDIR="${SYNC_REMOTE_PATH%/*}"

mkdir -p "$CONFIG_DIR"
touch "$SEEN_CACHE" 2>/dev/null

# ── Notification backend ───────────────────────────────────────────────────────

_notify() {
    local title="$1" body="$2"
    if command -v notify-send &>/dev/null; then
        notify-send \
            --urgency=normal \
            --icon=dialog-warning \
            --app-name="ssh_shorty" \
            "$title" "$body"
    else
        # Fallback: write to stderr (visible in journalctl --user -u s-admin-watch)
        printf '[s-admin-watch] %s — %s\n' "$title" "$body" >&2
    fi
}

# ── Main loop ──────────────────────────────────────────────────────────────────

if [[ -z "$SYNC_HOST" ]]; then
    printf '[s-admin-watch] SYNC_HOST not set in %s/config — exiting.\n' \
        "$CONFIG_DIR" >&2
    exit 1
fi

printf '[s-admin-watch] started. Polling %s every %ss.\n' \
    "$SYNC_HOST" "$SHORTY_WATCH_INTERVAL" >&2

while true; do
    # Fetch current list of pending .req filenames from SYNC_HOST
    req_list=$(ssh -q -o BatchMode=yes -o ConnectTimeout=5 "$SYNC_HOST" \
        "ls ~/${RDIR}/pending_requests/*.req 2>/dev/null" 2>/dev/null)

    if [[ -n "$req_list" ]]; then
        new_lines=""

        while IFS= read -r req_path; do
            [[ -z "$req_path" ]] && continue
            req_base=$(basename "$req_path")

            # Skip if already notified about this request
            grep -qxF "$req_base" "$SEEN_CACHE" 2>/dev/null && continue

            # Mark as seen
            printf '%s\n' "$req_base" >> "$SEEN_CACHE"

            # Parse: TIMESTAMP_user_device.req
            base="${req_base%.req}"
            ts="${base%%_*}"
            rest="${base#*_}"
            req_user="${rest%%_*}"
            req_device="${rest#*_}"
            new_lines+="${req_user} wants access to ${req_device}\n"
        done <<< "$req_list"

        if [[ -n "$new_lines" ]]; then
            count=$(printf '%b' "$new_lines" | grep -c .)
            _notify \
                "Fleet: ${count} access request(s)" \
                "$(printf '%b' "$new_lines")→ s-admin --pending-requests"
        fi

        # Prune seen cache — remove entries no longer in the pending list
        # (cleared after admin grants access)
        tmp=$(mktemp)
        while IFS= read -r cached; do
            [[ -z "$cached" ]] && continue
            grep -qF "$cached" <<< "$req_list" && printf '%s\n' "$cached"
        done < "$SEEN_CACHE" > "$tmp"
        mv "$tmp" "$SEEN_CACHE"
    else
        # No pending requests — reset seen cache so re-submissions notify again
        : > "$SEEN_CACHE"
    fi

    sleep "$SHORTY_WATCH_INTERVAL"
done
